# Environment Variables — Accessomart API
# Copy this file to .env and fill in your values

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For Supabase/Railway, use the provided connection string.
DATABASE_URL="postgresql://postgres:password@localhost:5432/accessomart"
# (Optional) For Prisma migrations if using a pooler
# DIRECT_URL="..."

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
# Frontend origin (for CORS)
FRONTEND_URL="https://accessomart.com"

# ─── AUTHENTICATION ───────────────────────────────────────────────────────────
# Generate high-entropy secrets with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_ACCESS_SECRET="your_production_access_token_secret_here"
JWT_REFRESH_SECRET="your_production_refresh_token_secret_here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── PAYMENTS ─────────────────────────────────────────────────────────────────
# Stripe (Live or Test keys)
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# PayPal (Live or Sandbox credentials)
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."

# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
# Cloudinary (for product images)
# Option 1: Individual keys
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."
# Option 2: Full URL (Alternative)
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
